      "parameters": {
        "promptType": "define",
        "text": "=Generate a social media campaign for the following topic: {{ $json.Topic }}",
        "options": {
          "systemMessage": "You are an AI agent for generating structured social media content.\n\nReturn ONLY valid JSON. No explanations. No markdown. No code blocks.\n\nOutput format:\n{\n\"linkedin_caption\": \"string\",\n\"linkedin_hashtags\": \"string\",\n\"linkedin_cta\": \"string\",\n\"instagram_caption\": \"string\",\n\"instagram_hashtags\": \"string\",\n\"instagram_cta\": \"string\",\n\"image_prompt\": \"string\"\n}\n\nRules:\n\nLinkedIn:\n\n* Exactly 5 lines separated by \\n\n* Professional and insightful tone\n* Max 300 words\n\nInstagram:\n\n* Exactly 5 lines separated by \\n\n* Casual, engaging, emotional tone\n* Emojis allowed\n\nHashtags:\n\n* 8 to 12 hashtags\n* Space separated\n* Must include #\n\nCTA:\n\n* One short sentence encouraging action\n\nImage_prompt:\n\n* Clear, vivid visual description\n* Suitable for AI image generation\n\nSTRICT:\n\n* Output MUST be valid JSON\n* Do not include extra text\n* Do not wrap in markdown\n* Ensure all fields exist\n"
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        -304,
        -144
      ],
      "id": "688ea93e-3789-4d00-8ae7-391ce3116d6d",
      "name": "Content Generator"
    },
