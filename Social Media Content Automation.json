    {
      "parameters": {
        "jsCode": "let raw = $json.output || \"\";\n\n// Step 1: Remove markdown blocks\nraw = raw\n  .replace(/```json/gi, '')\n  .replace(/```/g, '')\n  .trim();\n\n// Step 2: Extract JSON if extra text exists\nconst firstBrace = raw.indexOf('{');\nconst lastBrace = raw.lastIndexOf('}');\n\nif (firstBrace !== -1 && lastBrace !== -1) {\n  raw = raw.substring(firstBrace, lastBrace + 1);\n}\n\nlet parsed;\n\ntry {\n  parsed = JSON.parse(raw);\n} catch (error) {\n  return [\n    {\n      json: {\n        error: \"Invalid JSON from AI\",\n        raw_output: raw\n      }\n    }\n  ];\n}\n\n// Step 3: Validate required fields\nconst requiredFields = [\n  \"linkedin_caption\",\n  \"linkedin_hashtags\",\n  \"linkedin_cta\",\n  \"instagram_caption\",\n  \"instagram_hashtags\",\n  \"instagram_cta\",\n  \"image_prompt\"\n];\n\nfor (const field of requiredFields) {\n  if (!parsed[field]) {\n    parsed[field] = \"MISSING\";\n  }\n}\n\nreturn [\n  {\n    json: parsed\n  }\n];"
      },
